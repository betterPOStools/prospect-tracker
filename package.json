    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.2",
    "vitest": "^3.1.4"
