    "@capacitor/network": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-virtual": "^3.13.4",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.51.1",
